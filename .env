# ============================================
# 内网语音识别及文档生成系统 - 配置文件
# 部署时只需修改此文件即可
# ============================================

# --- 服务器配置 ---
# HOST: 监听地址，0.0.0.0 表示所有网卡均可访问
# PORT: 监听端口
HOST=0.0.0.0
PORT=6543

# --- HTTPS 配置 ---
# ENABLE_HTTPS: True=启用HTTPS，False=仅HTTP
# 启用后浏览器才能在非localhost环境下使用麦克风
# 首次使用请运行 python generate_cert.py 生成证书
ENABLE_HTTPS=True
SSL_CERT=cert/cert.pem
SSL_KEY=cert/key.pem

# --- AI 服务配置 ---
# 核心开关：True=内网部署模式，False=外网开发模式(阿里云 DashScope)
USE_INTRANET=False

# 外网开发配置 (阿里云 DashScope)
ONLINE_API_KEY=sk-4016b26700e2419fb1fdedc04164dbf5
ONLINE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ONLINE_ASR_MODEL=qwen3-asr-flash-2026-02-10
ONLINE_LLM_MODEL=qwen-plus-2025-07-28
ONLINE_ASR_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ONLINE_ASR_API_KEY=sk-4016b26700e2419fb1fdedc04164dbf5
ONLINE_REALTIME_MIN_AUDIO_SECONDS=1.5
MEDIUM_REWRITE_SECONDS=6.0
IDLE_SEGMENT_SPLIT_SECONDS=0.0
HIGH_REWRITE_SEGMENT_SPLIT_MIN_CHARS=100
IDLE_ACTIVITY_MIN_RMS=0.0034
IDLE_ACTIVITY_MIN_PEAK=224
IDLE_ACTIVITY_MIN_ACTIVE_RATIO=0.20
IDLE_ACTIVITY_MIN_VOICED_RATIO=0.12
IDLE_ACTIVITY_MIN_ACTIVE_RUN_SECONDS=0.09
IDLE_ACTIVITY_MIN_VOICED_RUN_SECONDS=0.06
IDLE_ACTIVITY_MIN_VOICED_DENSITY=0.35

# 内网部署配置 (私有化部署)
# 请替换为你们内网 AI 服务器的实际地址
INTRANET_API_KEY=
INTRANET_BASE_URL=http://192.168.1.100:8000/v1
INTRANET_ASR_MODEL=Qwen/Qwen3-ASR-1.7B
INTRANET_LLM_MODEL=qwen2.5-7b
INTRANET_ASR_BASE_URL=http://127.0.0.1:30000/v1
INTRANET_ASR_API_KEY=

# --- 目录配置 ---
EXPORT_DIR=exports
TEMP_DIR=temp_audio
